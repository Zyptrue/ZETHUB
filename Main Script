    distLabel.BackgroundTransparency = 1
    distLabel.Text = "[0m]"
    distLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    distLabel.TextStrokeTransparency = 0
    distLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    distLabel.Font = Enum.Font.GothamBold
    distLabel.TextSize = 11
    distLabel.Parent = billboard
    
    otherESP[item] = {
        billboard = billboard,
        distLabel = distLabel,
        anchor = anchor
    }
    
    print("[ESP] Other Detection: " .. itemName)
end

-- ==========================================
-- Remove ESP from one item
-- ==========================================
local function removeOtherESP(item)
    if otherESP[item] then
        pcall(function()
            if otherESP[item].billboard then
                otherESP[item].billboard:Destroy()
            end
        end)
        otherESP[item] = nil
    end
end

-- ==========================================
-- Remove All ESP
-- ==========================================
local function clearAllOtherESP()
    for item, _ in pairs(otherESP) do
        removeOtherESP(item)
    end
end

-- ==========================================
-- Scan All item "Other" di folder Tools
-- ==========================================
local function scanAllOther()
    local toolsFolder = Workspace:FindFirstChild("Tools")
    if not toolsFolder then return 0 end
    
    local count = 0
    for _, item in ipairs(toolsFolder:GetChildren()) do
        if isRegisteredOther(item) then
            createOtherESP(item)
            if otherESP[item] then count = count + 1 end
        end
    end
    
    print("[OtherESP] Scan selesai. Total item 'Other' terdeteksi: " .. count)
    return count
end

-- ==========================================
-- Loop Update Meter
-- ==========================================
local function startUpdateLoop()
    if updateConnection then updateConnection:Disconnect() end
    
    updateConnection = RunService.RenderStepped:Connect(function()
        local myChar = lp.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        
        local toRemove = {}
        
        for item, data in pairs(otherESP) do
            local success = pcall(function()
                local anchor = data.anchor
                local distLabel = data.distLabel
                
                if not anchor or not anchor.Parent then
                    table.insert(toRemove, item)
                    return
                end
                
                local distance = (myHRP.Position - anchor.Position).Magnitude
                distLabel.Text = string.format("[%dm]", math.floor(distance))
                
                -- Warna jarak
                if distance < 10 then
                    distLabel.TextColor3 = Color3.fromRGB(255, 50, 50)   -- Merah (dekat)
                elseif distance < 30 then
                    distLabel.TextColor3 = Color3.fromRGB(255, 200, 0)   -- Kuning
                else
                    distLabel.TextColor3 = Color3.fromRGB(0, 255, 0)     -- Hijau (jauh)
                end
            end)
            
            if not success then
                table.insert(toRemove, item)
            end
        end
        
        for _, item in ipairs(toRemove) do
            removeOtherESP(item)
        end
    end)
end

-- ==========================================
-- Deteksi Item Baru / Item Hilang
-- ==========================================
local function setupOtherFolderListener()
    if listenerConnected then return end
    
    local toolsFolder = Workspace:FindFirstChild("Tools")
    if not toolsFolder then return end
    
    -- Item baru muncul
    toolsFolder.ChildAdded:Connect(function(child)
        if not espEnabled then return end
        if isRegisteredOther(child) then
            task.wait(0.2)
            createOtherESP(child)
        end
    end)
    
    -- Item hilang (diambil player)
    toolsFolder.ChildRemoved:Connect(function(child)
        if otherESP[child] then
            removeOtherESP(child)
        end
    end)
    
    listenerConnected = true
end

-- ==========================================
-- Toggle Other ESP ON/OFF
-- ==========================================
local function toggleOtherESP(state)
    espEnabled = state
    
    if state then
        local toolsFolder = Workspace:FindFirstChild("Tools")
        if not toolsFolder then
            toolsFolder = Workspace:WaitForChild("Tools", 15)
        end
        
        if toolsFolder then
            scanAllOther()
            setupOtherFolderListener()
            startUpdateLoop()
        end
    else
        if updateConnection then
            updateConnection:Disconnect()
            updateConnection = nil
        end
        clearAllOtherESP()
    end
end

